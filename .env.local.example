# Copy this file to .env.local and fill in values from `cdk deploy` outputs.
# Without these, the app works normally but cross-device sync is disabled.

NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_xxxxxxxxx
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_API_ENDPOINT=https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com
